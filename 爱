  <title>给你看个东西</title>
  <style>
    * {
      margin: 0;
      填充: 0;
      盒模型: border-box;
    }

    body {
      背景: 径向渐变(椭圆在中心, #1a0a2e 0%, #0b0b1a 100%);
      宽度：100vw；
      高度：100vh；
      溢出: 隐藏;
      字体：'PingFang SC'，'Hiragino Sans GB'，'Microsoft YaHei'，无衬线
      显示：弹性布局；
      对齐项目：居中；
      文本对齐方式：居中；
      触摸动作：操作；
      -webkit-tap-highlight-color: 透明;
    }

    画布 {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    .text-container {
      position: relative;
      z-index: 10;
      text-align: center;
      color: #fff;
      opacity: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.8rem;
      transition: opacity 1.2s ease;
      pointer-events: none;
    }

    .text-container.visible {
      opacity: 1;
    }

    .main-line {
      font-size: 2.6rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-shadow: 0 0 30px rgba(255, 200, 220, 0.7);
      animation: softPulse 2.8s ease-in-out infinite;
      font-family: "STKaiti", "KaiTi", "楷体", "PingFang SC", serif;
    }

    .sub-line {
      font-size: 1.4rem;
      font-weight: 300;
      opacity: 0;
      animation: fadeSlideUp 1.6s ease forwards;
      animation-delay: 1.3s;
      letter-spacing: 0.15em;
      color: rgba(255, 255, 255, 0.85);
      text-shadow: 0 0 12px rgba(255, 180, 200, 0.5);
    }

    .hint-line {
      font-size: 0.95rem;
      margin-top: 2rem;
      opacity: 0;
      animation: fadeIn 2s ease forwards;
      animation-delay: 3.2s;
      color: rgba(255, 255, 255, 0.5);
      letter-spacing: 0.1em;
    }

    @keyframes softPulse {
      0%, 100% {
        text-shadow: 0 0 30px rgba(255, 180, 200, 0.7);
      }
      50% {
        text-shadow: 0 0 60px rgba(255, 160, 180, 0.9), 0 0 100px rgba(200, 120, 160, 0.4);
      }
    }

    @keyframes fadeSlideUp {
      0% {
        opacity: 0;
        transform: translateY(20px);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeIn {
      to {
        opacity: 1;
      }
    }
  </style>
</head>
